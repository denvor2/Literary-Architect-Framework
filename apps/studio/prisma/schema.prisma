generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AssistantSettings {
  id              String        @id
  mode            AssistantRole @unique
  displayName     String?
  promptSuffix    String?
  typicalRequests String[]      @default([])
  updatedAt       DateTime
}

model AssistantThread {
  id          String        @id
  bookId      String
  role        AssistantRole
  name        String
  persona     String?
  Book        Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  ChatMessage ChatMessage[]

  @@index([bookId])
  @@index([bookId, role])
}

model Book {
  id                    String            @id
  userId                String
  title                 String
  genre                 Json?             // Story Bible: ["Fantasy", "Sci-Fi"] — array of genres
  language              String
  premise               String            @default("")
  shortAnnotation       String            @default("")
  fullAnnotation        String            @default("")
  tags                  String[]          @default([])
  createdAt             DateTime          @default(now())
  updatedAt             DateTime
  seriesId              String?
  deletedAt             DateTime?

  // Story Bible fields
  workingTitle          String?           // Working/draft title
  targetAudience        String?           // e.g., "Adult", "YA", "Teen"
  estimatedWordCount    Int?              // Estimated word count for this book
  estimatedChapters     Int?              // Planned chapter count
  status                BookStatus?       // outline | draft | editing | beta | published
  mainPlotlines         Json?             // Array of main plotlines: ["Jordan (WildMind)", "Professor zoologist"]
  principle             String?           // e.g., "Contrast. Chapters constantly switch POV."
  escalation            String?           // e.g., "Sticks → Dolphins → Xenosys → Bears"
  themes                Json?             // Array of themes: ["What is consciousness?", "Should we destroy new intelligence?"]
  bookConstraints       Json?             // Array of constraints (what NOT to do): ["Don't overuse scientific jargon"]
  notes                 String?           // Internal notes
  publishedDate         DateTime?         // Publication date
  isbn                  String?           // ISBN for published books

  AssistantThread       AssistantThread[]
  Series                Series?           @relation(fields: [seriesId], references: [id])
  User                  User              @relation(fields: [userId], references: [id])
  Chapter               Chapter[]
  Character             Character[]
  Idea                  Idea[]

  @@index([seriesId])
  @@index([userId, deletedAt])
}

model Chapter {
  id       String  @id
  bookId   String
  title    String
  subtitle String  @default("")
  order    Int     @default(0)
  Book     Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  Scene    Scene[]

  @@index([bookId])
}

model CustomExpert {
  id              String    @id @default(cuid())
  userId          String
  name            String
  systemPrompt    String    @db.Text
  typicalRequests String[]  @default([])
  icon            String    @default("🤖")
  isPublic        Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  User            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([isPublic, deletedAt])
}

model PublicExpert {
  id              String   @id @default(cuid())
  creatorId       String
  originalId      String?
  name            String
  systemPrompt    String   @db.Text
  typicalRequests String[] @default([])
  icon            String   @default("🤖")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([creatorId])
}

model UserPublicExpert {
  id        String   @id @default(cuid())
  userId    String
  publicId  String
  addedAt   DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId])
}

model Character {
  id          String @id
  bookId      String
  name        String
  description String @default("")
  notes       String @default("")
  photoUrl    String @default("")
  Book        Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model ChatMessage {
  id              String          @id
  threadId        String
  role            MessageRole
  content         String
  createdAt       DateTime        @default(now())
  AssistantThread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Event {
  id        String    @id
  userId    String
  eventType EventType
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([eventType])
  @@index([userId, eventType, createdAt])
  @@index([userId])
}

model EventArchive {
  id         String    @id
  userId     String
  eventType  EventType
  metadata   Json?
  createdAt  DateTime
  archivedAt DateTime  @default(now())

  @@index([archivedAt])
  @@index([createdAt])
  @@index([eventType])
  @@index([userId])
}

model Idea {
  id        String   @id
  bookId    String
  text      String
  createdAt DateTime @default(now())
  Book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model Payment {
  id                 String           @id
  userId             String
  userSubscriptionId String
  amount             Int
  status             PaymentStatus    @default(pending)
  externalPaymentId  String?
  paymentMethod      String?
  failureReason      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime
  User               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  UserSubscription   UserSubscription @relation(fields: [userSubscriptionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userSubscriptionId])
}

model Plan {
  id                   String             @id
  name                 String             @unique
  tier                 String             @unique
  price                Int                @default(0)
  billingPeriodDays    Int                @default(30)
  maxBooks             Int                @default(0)
  maxAssistants        Int                @default(0)
  maxAssistantRequests Int                @default(0)
  maxCharactersPerReq  Int                @default(0)
  features             String[]           @default([])
  description          String?
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  UserSubscription     UserSubscription[]
}

model Scene {
  id        String  @id
  chapterId String
  title     String
  text      String  @default("")
  order     Int     @default(0)
  Chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model Series {
  id                       String         @id
  userId                   String
  title                    String
  description              String?
  order                    Int            @default(0)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime

  // Story Bible fields
  targetAudience           String?        // e.g., "Adult", "YA", "Teen"
  genre                    Json?          // Array of genres for entire series: ["Fantasy", "Sci-Fi"]
  estimatedTotalWordCount  Int?           // Estimated total word count for entire series
  status                   SeriesStatus?  // outline | in_progress | complete | published
  decisions                String?        // High-level creative decisions
  throughlineElements      Json?          // Array of throughline elements: ["WildMind", "Jordan", "philosophical questions"]
  seriesConstraints        Json?          // Array of series-level constraints: ["No absolute villains"]
  notes                    String?        // Internal notes
  firstPublishedDate       DateTime?      // First publication date
  author                   String?        // Author name (if different from User)

  Book                     Book[]
  User                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                    String            @id
  createdAt             DateTime          @default(now())
  email                 String            @unique
  passwordHash          String?
  role                  Role              @default(user)
  isBlocked             Boolean           @default(false)
  updatedAt             DateTime
  lastSelectedMode      String?           @default("coauthor") // "coauthor" | "editor" | "critic" | "reader"
  lastSelectedExpertId  String?           // null if mode is selected, expert id if expert is selected
  Book                  Book[]
  Event                 Event[]
  Payment               Payment[]
  Series                Series[]
  UserSubscription      UserSubscription?
  CustomExpert          CustomExpert[]
  UserPublicExpert      UserPublicExpert[]

  @@index([email])
}

model UserSubscription {
  id                     String             @id
  userId                 String             @unique(map: "unique_active_subscription_per_user")
  planId                 String
  status                 SubscriptionStatus @default(active)
  startDate              DateTime           @default(now())
  endDate                DateTime?
  externalSubscriptionId String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  Payment                Payment[]
  Plan                   Plan               @relation(fields: [planId], references: [id])
  User                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum AssistantRole {
  coauthor
  editor
  critic
  reader
}

enum BookStatus {
  outline
  draft
  editing
  beta
  published
}

enum SeriesStatus {
  outline
  in_progress
  complete
  published
}

enum EventType {
  login_success
  login_failure
  logout
  register_success
  book_created
  book_updated
  book_deleted
  chapter_created
  chapter_updated
  chapter_deleted
  scene_created
  scene_updated
  scene_deleted
  ai_request_line_editor
  ai_request_critic
  ai_request_reader
  ai_request_coauthor
  subscription_created
  subscription_updated
  subscription_expired
  subscription_cancelled
  payment_created
  payment_completed
  payment_failed
  workspace_updated
}

enum MessageRole {
  user
  assistant
}

enum PaymentStatus {
  pending
  completed
  failed
}


enum Role {
  admin
  user
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}
