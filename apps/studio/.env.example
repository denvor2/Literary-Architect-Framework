# ============================================================================
# Literary Studio Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the real values there.
# This file (.env.example) is committed and contains placeholders only.
# Never commit real values to this file.
#
# For deployment instructions, see: docs/project/DEPLOYMENT.md
#
# Secrets policy (see docs/vision/security.md):
# - Real values live only in .env.local (gitignored, never committed).
# - This file (.env.example) is committed and contains placeholders only.
# - Never log values, never expose to client-side code (no NEXT_PUBLIC_ prefix).
# ============================================================================

# --- REQUIRED VARIABLES ---

# Anthropic API Key (for AI Experts)
# - Required: YES (always)
# - Where used: apps/studio/src/lib/ai/anthropic.ts (Route Handler only)
# - Security: Server-side only (no NEXT_PUBLIC_ prefix)
# - Get one: https://console.anthropic.com/
# - Example: sk-ant-v0-...
ANTHROPIC_API_KEY=

# Database Connection String (PostgreSQL + Prisma adapter)
# - Required: YES (for production and Docker)
# - Optional: NO for local development with localStorage-only mode
# - Where used: apps/studio/src/lib/db.ts, Prisma schema
# - Format: postgresql://user:password@host:port/database?schema=public
# - Local dev: postgresql://literary:literary@localhost:5432/literary_studio
# - Docker Compose: postgres host is 'postgres' service name
# - Production: Use managed database (AWS RDS, DigitalOcean, Heroku, etc.)
DATABASE_URL=

# --- OPTIONAL VARIABLES ---

# Node Environment (development or production)
# - Required: NO
# - Default: production (Docker Dockerfile), development (npm run dev)
# - Where used: apps/studio/src/lib/db.ts (logging control)
# - Values: development | production
NODE_ENV=production

# Server Port (HTTP listener)
# - Required: NO
# - Default: 3000
# - Where used: Next.js server on 'npm run start', Docker EXPOSE
PORT=3000

# Server Hostname (bind address)
# - Required: NO
# - Default: 0.0.0.0 (listen on all interfaces)
# - Local dev: 127.0.0.1 (loopback only)
# - Production/Docker: 0.0.0.0 (all interfaces)
HOSTNAME=0.0.0.0

# --- RATE LIMITING ---

# Enable rate limiting on API endpoints
# - Required: NO
# - Default: true (enabled)
# - Where used: apps/studio/src/lib/rateLimit.ts
# - Values: "true" | "false" (set to "false" to disable)
RATE_LIMIT_ENABLED=true

# Maximum number of API requests per rate limit window
# - Required: NO (only if RATE_LIMIT_ENABLED is true)
# - Default: 10 requests per window
# - Where used: apps/studio/src/lib/rateLimit.ts
RATE_LIMIT_REQUESTS_PER_WINDOW=10

# Rate limit window duration in milliseconds
# - Required: NO (only if RATE_LIMIT_ENABLED is true)
# - Default: 900000 ms (15 minutes)
# - Examples: 300000 = 5 min, 900000 = 15 min, 3600000 = 1 hour
RATE_LIMIT_WINDOW_MS=900000

# --- NEXT.JS SYSTEM VARIABLES (managed by framework) ---

# Disable Next.js telemetry collection
# - Default: 0 (enabled) - set to 1 in production (see Dockerfile)
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# DEPLOYMENT QUICK REFERENCE
# ============================================================================
#
# LOCAL DEVELOPMENT (npm run dev):
#   - ANTHROPIC_API_KEY: REQUIRED (set in .env.local)
#   - DATABASE_URL: optional (defaults to localStorage)
#   - NODE_ENV: leave blank (auto-defaults to development)
#   - Rate limit vars: use defaults or override as needed
#
# DOCKER COMPOSE (docker-compose up):
#   - ANTHROPIC_API_KEY: REQUIRED (read from .env.local)
#   - DATABASE_URL: auto-set by docker-compose.yml
#   - NODE_ENV: auto-set to production by Dockerfile
#   - PORT/HOSTNAME: auto-set by Dockerfile
#   - Rate limit vars: inherit from .env.local
#
# PRODUCTION (VPS / Cloud):
#   - ANTHROPIC_API_KEY: REQUIRED (from secrets management)
#   - DATABASE_URL: REQUIRED (managed database service)
#   - NODE_ENV: REQUIRED (set to 'production')
#   - PORT: set to match reverse proxy or load balancer
#   - HOSTNAME: set to 0.0.0.0 (containerized) or specific IP
#   - Rate limit: adjust REQUESTS_PER_WINDOW based on expected load
#
# See docs/project/DEPLOYMENT.md for detailed setup.
# ============================================================================
